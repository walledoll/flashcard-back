generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthMethod {
  BYPASS
  GOOGLE
  GITHUB
}

model User {
  id           Int        @default(autoincrement()) @id
  email        String     @unique
  name         String
  passwordHash String?
  authMethod   AuthMethod @default(GOOGLE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions Session[]
  decks    Deck[]
  cards    Card[]
}

model Session {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Deck {
  id          Int      @default(autoincrement()) @id
  title       String
  description String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards Card[]

  @@index([userId])
  @@index([isPublic])
}

model Card {
  id           Int       @default(autoincrement()) @id
  front        String // Вопрос/термин
  back         String // Ответ/определение
  deckId       Int
  deck         Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  difficulty   Int       @default(3) // 1-5, где 5 - самый сложный
  lastReviewed DateTime?
  reviewCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([deckId])
  @@index([userId])
  @@index([difficulty])
}
